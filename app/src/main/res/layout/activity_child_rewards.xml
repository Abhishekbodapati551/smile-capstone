<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_child">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/rewards_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎁 Reward Store"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardBackgroundColor="@color/child_pink"
                    app:cardCornerRadius="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Your Available Points"
                            android:textColor="@color/white"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/points_val"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐ Loading..."
                            android:textColor="@color/white"
                            android:textSize="28sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:columnCount="2">

            <!-- Item 1: Star Badge -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="20dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐" android:textSize="40sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Star Badge" android:textStyle="bold" android:layout_marginTop="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100 Points" android:textColor="@color/text_secondary"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_buy_star"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Collect" android:layout_marginTop="8dp" app:cornerRadius="12dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Item 2: Pens Set -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="20dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🖋️" android:textSize="40sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pens Set" android:textStyle="bold" android:layout_marginTop="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="200 Points" android:textColor="@color/text_secondary"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_buy_pens"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Collect" android:layout_marginTop="8dp" app:cornerRadius="12dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Item 3: Teddy Bear -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="20dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🧸" android:textSize="40sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Teddy Bear" android:textStyle="bold" android:layout_marginTop="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="300 Points" android:textColor="@color/text_secondary"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_buy_teddy"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Collect" android:layout_marginTop="8dp" app:cornerRadius="12dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Item 4: Ice Cream Kit -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="20dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🍦" android:textSize="40sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ice Cream Kit" android:textStyle="bold" android:layout_marginTop="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="500 Points" android:textColor="@color/text_secondary"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_buy_icecream"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Collect" android:layout_marginTop="8dp" app:cornerRadius="12dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
